{
  "name": "Flow",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "site": {
      "type": "string",
      "enum": [
        "joe",
        "ignition",
        "ppsr",
        "double"
      ]
    },
    "description": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "navigate",
              "type",
              "click",
              "wait",
              "screenshot",
              "assert"
            ]
          },
          "selector": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "delay_ms": {
            "type": "number"
          },
          "notes": {
            "type": "string"
          },
          "on_error": {
            "type": "string",
            "enum": [
              "retry",
              "abort",
              "continue"
            ]
          },
          "retry_count": {
            "type": "number"
          }
        }
      }
    },
    "version": {
      "type": "number",
      "default": 1
    },
    "repair_confidence": {
      "type": "number",
      "default": 1
    },
    "last_repair_date": {
      "type": "string",
      "format": "date-time"
    },
    "change_summary": {
      "type": "string"
    },
    "is_default": {
      "type": "boolean",
      "default": false
    },
    "mode": {
      "type": "string",
      "enum": [
        "recorder",
        "fast_fill"
      ],
      "default": "recorder",
      "description": "Authoring mode \u2014 recorder builds step-by-step, fast_fill is a single inject+submit action."
    },
    "fast_fill": {
      "type": "object",
      "description": "Configuration for fast_fill mode",
      "properties": {
        "target_url": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "username_selector": {
          "type": "string"
        },
        "password_selector": {
          "type": "string"
        },
        "submit_selector": {
          "type": "string"
        },
        "credential_id": {
          "type": "string"
        },
        "totp_field_selector": {
          "type": "string"
        },
        "auto_submit": {
          "type": "boolean",
          "default": true
        },
        "wait_after_load_ms": {
          "type": "number",
          "default": 400
        }
      }
    }
  },
  "required": [
    "name",
    "site"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}